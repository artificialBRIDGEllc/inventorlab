# InventorLab — Environment Variables
DATABASE_URL=postgresql://user:password@host:5432/inventorlab
SESSION_SECRET=your-strong-secret-min-32-chars
ANTHROPIC_API_KEY=sk-ant-...
# RFC 3161 Timestamping (DigiCert or Entrust TSA)
TSA_URL=http://timestamp.digicert.com
TSA_POLICY_OID=2.16.840.1.114412.7.1
# Optional
NEWS_API_KEY=
PORT=5001
NODE_ENV=development